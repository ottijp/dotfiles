#!/bin/bash
set -euo pipefail

if [ "$#" -lt 2 ]; then
  echo "usage: $0 <new-branch> <path>" >&2
  exit 1
fi

new_branch=$1
path=$2
from=${3:-HEAD}

echo "creating new worktree: new-branch=\"$new_branch\" path=\"$path\" from=\"$from\"" >&2

git worktree add -b "$new_branch" "$path" "$from"
if [ -f "AGENTS.md" ]; then
  ln -s "$PWD/AGENTS.md" "$path"
  echo "symlink created: \"$path/AGENTS.md\" -> \"AGENTS.md\"" >&2
fi
if [ -d ".codex" ]; then
  ln -s "$PWD/.codex" "$path"
  echo "symlink created: \"$path/.codex\" -> \".codex\"" >&2
fi
if [ -d ".agents" ]; then
  ln -s "$PWD/agents" "$path"
  echo "symlink created: \"$path/agents\" -> \"agents\"" >&2
fi
